{
    "name": "poeticsoft-heart/babel",
    "version": "1.0.0",
    "description": "WordPress Babel Plugin - RAG server integration with Ollama and ChromaDB.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Alberto en Poeticsoft",
            "email": "alberto@poeticsoft.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Poeticsoft\\Heart\\Babel\\": "classes/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "format": "vendor/bin/phpcbf",
        "lint": "vendor/bin/phpcs"
    },
    "require": {
        "guzzlehttp/guzzle": "^7.12",
        "smalot/pdfparser": "^2.12"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.10"
    }
}
