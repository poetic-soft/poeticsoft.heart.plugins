{
  "name": "poeticsoft.heart.campus",
  "version": "0.0.0",
  "license": "GPL-2.0-or-later",
  "scripts": {

    "blockbreadcrumbs": "webpack --env=block-breadcrumbs",
    "blockcolumntools": "webpack --env=block-columntools",
    "blockcontainerchildren": "webpack --env=block-containerchildren",
    "blockmytools": "webpack --env=block-mytools",  
    "blockrelatedcontent": "webpack --env=block-relatedcontent",
    "blocklastpublished": "webpack --env=block-lastpublished",
    "blocktreenav": "webpack --env=block-treenav",
    "allblocks": "npm run blockbreadcrumbs && npm run blockcolumntools && npm run blockcontainerchildren && npm run blockmytools && npm run blockrelatedcontent && npm run blocktreenav", 

    "adminpagesquickedit": "webpack --env=ui-admin/pagesquickedit",
    "adminpageslist": "webpack --env=ui-admin/pageslist",
    "adminaccess": "webpack --env=ui-admin/access",
    "alladmin": "npm run adminpagesquickedit && npm run adminpageslist && npm run adminaccess",

    "editcoreconfigs": "webpack --env=ui-edit/coreconfigs",
    "uipostcontent": "webpack --env=ui-frontend/postcontent",
    "allcontent": "npm run editcoreconfigs && npm run uipostcontent",

    "uiregisteraccess": "webpack --env=ui-frontend/registeraccess",

    "all": "npm run allblocks && npm run alladmin && npm run allcontent && npm run uiregisteraccess"
  },
  "dependencies": {
    "@babel/core": "^7.18.10",
    "@babel/preset-env": "^7.18.10",
    "@babel/preset-react": "^7.18.6",
    "@babel/runtime": "^7.18.9",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/multimonth": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@stripe/stripe-js": "^8.2.0",
    "immutable-update": "^1.0.0",
    "sass": "^1.89.2",
    "uuid": "^13.0.0"
  },
  "babel": {
    "presets": [
      "@babel/preset-env"
    ]
  },
  "devDependencies": {
    "webpack": "^5.100.2",
    "webpack-cli": "^6.0.1",
    "baseline-browser-mapping": "^2.9.14",
    "babel-loader": "^8.2.5",
    "css-loader": "^6.7.1",
    "style-loader": "^3.3.1",
    "sass-loader": "^13.0.2",
    "file-loader": "^6.2.0",
    "mini-css-extract-plugin": "^2.6.1"
  }
}
