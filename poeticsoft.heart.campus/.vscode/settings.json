{
  "phpcs.executablePath": "${workspaceFolder}/poeticsoft-heart-campus/vendor/bin/phpcs",
  "phpcbf.executablePath": "${workspaceFolder}/poeticsoft-heart-campus/vendor/bin/phpcbf",
  "phpcs.standard": "${workspaceFolder}/poeticsoft-heart-campus/phpcs.xml",
  "phpcbf.standard": "${workspaceFolder}/poeticsoft-heart-campus/phpcs.xml",
  "phpcs.ignore": [
    "**/vendor/*",
    "**/cache/*",
    "**/vendor/autoload.php"
  ],
  "intelephense.stubs": [
    "apache",
    "bcmath",
    "bz2",
    "calendar",
    "Core",
    "curl",
    "date",
    "dba",
    "dom",
    "enchant",
    "fileinfo",
    "filter",
    "ftp",
    "gd",
    "gettext",
    "gmp",
    "hash",
    "iconv",
    "imap",
    "intl",
    "json",
    "ldap",
    "libxml",
    "mbstring",
    "mcrypt",
    "meta",
    "mysqli",
    "oci8",
    "odbc",
    "openssl",
    "pcntl",
    "pcre",
    "PDO",
    "pdo_ibm",
    "pdo_mysql",
    "pdo_pgsql",
    "pdo_sqlite",
    "pgsql",
    "Phar",
    "posix",
    "pspell",
    "readline",
    "recode",
    "Reflection",
    "session",
    "shmop",
    "SimpleXML",
    "snmp",
    "soap",
    "sockets",
    "sodium",
    "SPL",
    "sqlite3",
    "standard",
    "superglobals",
    "sysvmsg",
    "sysvsem",
    "sysvshm",
    "tidy",
    "tokenizer",
    "xml",
    "xmlreader",
    "xmlrpc",
    "xmlwriter",
    "xsl",
    "Zend OPcache",
    "zip",
    "zlib",
    "wordpress"
  ],
  "intelephense.environment.includePaths": [
    "${workspaceFolder}/poeticsoft-heart-campus/vendor/php-stubs/wordpress-stubs"
  ],
  "[php]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
    "intelephense.format.braces": "psr12",
    "php.suggest.basic": false
  },
  // Configuración general del Workspace
  "editor.formatOnSave": true,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,

  // Configuración específica para JavaScript y React
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true,
    "editor.suggest.snippetsPreventQuickSuggestions": false
  },

  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true
  },

  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true
  },

  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true
  },

  // Importante: Forzar que los .js se traten como React para que el JSX no de errores
  "files.associations": {
    "*.js": "javascriptreact"
  },

  // Reglas de Prettier para este proyecto
  "prettier.tabWidth": 4, // <--- ESTA ES LA LÍNEA QUE FALTA
  "prettier.useTabs": false,
  "prettier.singleQuote": true,
  "prettier.trailingComma": "none",
  "prettier.printWidth": 100,
  "prettier.semi": true,

  "emmet.includeLanguages": {
    "javascript": "javascriptreact"
  },

  // Integración de ESLint y Stylelint para in-editor linting y auto-fix
  "eslint.validate": [
    "javascript",
    "javascriptreact"
  ],
  "stylelint.validate": [
    "css",
    "scss"
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit"
  }
}