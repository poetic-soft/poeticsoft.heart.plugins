<?xml version="1.0"?>
<ruleset name="ModernPHP">
    <description>Modern PHP PSR-12 coding standard without traditional spacing constraints.</description>

    <!-- Exclude third-party and built directories -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/ui/*</exclude-pattern>

    <!-- Scan the root directory -->
    <file>.</file>

    <!-- Only scan PHP files -->
    <arg name="extensions" value="php"/>

    <!-- Show progress and colors -->
    <arg value="sp"/>
    <arg name="colors"/>

    <!-- Use PSR-12 as the base standard -->
    <rule ref="PSR12">
        <!-- Allow snake_case method names standard in WordPress development -->
        <exclude name="PSR1.Methods.CamelCapsMethodName.NotCamelCaps"/>
    </rule>

    <!-- Enforce consistent line spacing -->
    <!-- Disallow multiple consecutive blank lines inside functions, classes, and files -->
    <rule ref="Squiz.WhiteSpace.SuperfluousWhitespace">
        <properties>
            <property name="ignoreBlankLines" value="false"/>
        </properties>
    </rule>
    <rule ref="Squiz.WhiteSpace.SuperfluousWhitespace.EmptyLines"/>


</ruleset>
